# 复制本文件为 .env 并填入你的密钥（.env 不会被提交）
# 说明：后端默认从这里读配置；如果 Qt 客户端在请求里带了 api_key，
#       则优先用客户端传来的（这样你可以只在 Qt 设置界面填一次）。
# 注意：本模板不含真实密钥，请填入你自己的。

# ---- DeepSeek（文本模型：摘要 / 润色 / RAG 生成）----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ---- 通义千问 DashScope（仅用于视觉模型 qwen3-vl-flash）----
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# ---- 本地 RAG（无需 Embedding API Key）----
LOCAL_EMBED_MODEL=jinaai/jina-embeddings-v5-text-nano
# 可选：显式指定 Hugging Face snapshot 目录，完全绕过在线模型解析
# LOCAL_EMBED_MODEL_PATH=C:\Users\你的用户名\.cache\huggingface\hub\models--jinaai--jina-embeddings-v5-text-nano\snapshots\<revision>
LOCAL_RAG_DIR=.
LOCAL_EMBED_BATCH_SIZE=16
MILVUS_INSERT_BATCH_SIZE=100
