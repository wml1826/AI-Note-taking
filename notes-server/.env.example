# 复制本文件为 .env 并填入你的密钥（.env 不会被提交）
# 说明：后端默认从这里读配置；如果 Qt 客户端在请求里带了 api_key，
#       则优先用客户端传来的（这样你可以只在 Qt 设置界面填一次）。
# 注意：本模板不含真实密钥，请填入你自己的。

# ---- DeepSeek（文本模型：摘要 / 润色 / RAG 生成）----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ---- 通义千问 DashScope（视觉模型 qwen3-vl-flash + RAG 向量化 text-embedding-v3）----
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# ---- RAG 检索（Python 负责：切块 + 向量化 + Chroma 向量库）----
# embedding 复用上面的 DASHSCOPE_API_KEY，无需单独申请 Key
EMBED_MODEL=text-embedding-v3
EMBED_DIM=1024
CHROMA_PATH=./chroma_data
